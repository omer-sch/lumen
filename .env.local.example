# ─────────────────────────────────────────
# Lumen — Environment Variables (example)
# Copy to `.env.local` and fill in real values.
# `.env.local` is gitignored. Never commit secrets.
# ─────────────────────────────────────────

# ── Clerk (Authentication) ──
# https://dashboard.clerk.com → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx

# Clerk redirect paths (defaults, override only if needed)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_OUT_URL=/sign-in

# ── Anthropic (Claude API) ──
# Server-only. Never expose to the browser.
# https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# ── Sentry (Error Tracking) ──
# https://sentry.io → Your Project → Settings → Client Keys (DSN)
# SENTRY_DSN is server-only. NEXT_PUBLIC_SENTRY_DSN is used by the browser SDK.
# Both point to the same DSN value.
SENTRY_DSN=https://xxxxxxxxxxxx@oXXXXXX.ingest.sentry.io/XXXXXXX
NEXT_PUBLIC_SENTRY_DSN=https://xxxxxxxxxxxx@oXXXXXX.ingest.sentry.io/XXXXXXX
# Optional — required only if you want source maps uploaded on `next build`
SENTRY_ORG=your-sentry-org-slug
SENTRY_PROJECT=lumen

# ── PostHog (Product Analytics) ──
# https://us.posthog.com → Your Project → Settings → Project API key
NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ── LangSmith (Hermes observability, optional) ──────────────────────
# Set LANGSMITH_TRACING=true and add LANGSMITH_API_KEY to enable
# per-run traces of the Hermes graph at app.smith.langchain.com.
# Leave empty in dev unless you want traces; production should opt in.
# Get an API key at smith.langchain.com -> Settings -> API keys.
LANGSMITH_TRACING=
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=lumen-hermes-dev
LANGSMITH_ENDPOINT=
